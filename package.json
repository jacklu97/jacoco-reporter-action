{
  "name": "jacoco-reporter-action",
  "scripts": {
    "build": "bun build src/main.ts --outdir dist --target node --minify",
    "dev": "run src/main.ts",
    "prepare": "husky",
    "lint": "biome lint src/",
    "check": "biome check --write src/"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@biomejs/biome": "^2.4.11",
    "bun-types": "^1.3.11",
    "husky": "^9.1.7"
  }
}
